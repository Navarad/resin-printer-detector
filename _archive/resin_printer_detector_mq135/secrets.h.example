// Copy this file to `secrets.h` and fill in your values.
// `secrets.h` is git-ignored so your credentials stay local.

#pragma once

// The Wi-Fi network this ESP32 will create (Shelly connects to it).
// SSID max 32 chars, password min 8 chars.
#define SECRET_AP_SSID     "YourAPName"
#define SECRET_AP_PASSWORD "YourStrongPassword"

// Fallback IP if dynamic detection isn't ready yet.
#define SECRET_SHELLY_IP   "192.168.4.50"
